# Production Environment Variables for cPanel Deployment
# Copy this file to .env.production and fill in your actual values

NODE_ENV=<env>

# Database Configuration
# Replace with your actual MySQL database connection string
DATABASE_URL="mysql://username:password@localhost:3306/<dbname>"

# NextAuth Configuration
# Generate a secure random string for NEXTAUTH_SECRET
NEXTAUTH_SECRET=""

# Application URL
NEXTAUTH_URL=""

# SMTP Email Configuration 
EMAIL_HOST=""
EMAIL_PORT=""
EMAIL_SECURE=""
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM_EMAIL=""
EMAIL_FROM_NAME=""

# Server Port
PORT=<PORT>
